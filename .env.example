# Copie este archivo como .env y cambie todos los valores CHANGE_ME.
# .env esta ignorado por Git y nunca debe subirse al repositorio.
DB_NAME=prestamos
DB_USER=CHANGE_ME_DB_USER
DB_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
DB_PORT=5432
APP_PORT=8080

# Seguridad opcional para /api/**.
APP_SECURITY_ENABLED=false
APP_API_KEY=CHANGE_ME_ONLY_IF_SECURITY_IS_ENABLED

# Administrador web opcional incluido en Compose.
PGADMIN_PORT=8082
PGADMIN_EMAIL=CHANGE_ME_ADMIN_EMAIL
PGADMIN_PASSWORD=CHANGE_ME_STRONG_PGADMIN_PASSWORD
